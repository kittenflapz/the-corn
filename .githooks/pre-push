#!/usr/bin/env bash
# Catch CI failures before they happen.
# Runs astro check + build. If either fails, push is aborted.
# Bypass with: git push --no-verify

set -e

echo "🌽 pre-push: running astro check..."
npm run check

echo "🌽 pre-push: running build..."
npm run build

echo "🌽 pre-push: all good, pushing."
