---
// Homepage — most recent non-draft article as hero, next 4 in a 2-col grid.
// Sorted by pubDate descending. Excludes drafts at build time.
import BaseLayout from "../layouts/BaseLayout.astro";
import Masthead from "../components/Masthead.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Enforce single-featured invariant at build time. Authors set `featured: true`
// on one article to pin it as the hero indefinitely; if two are flagged, fail
// the build loudly rather than silently picking one.
const featuredArticles = articles.filter((a) => a.data.featured);
if (featuredArticles.length > 1) {
  throw new Error(
    `Multiple articles flagged featured: ${featuredArticles.map((a) => a.id).join(", ")}. ` +
      "Only one article may be featured at a time — set featured: false on the others.",
  );
}

// Hero = the pinned featured article if any, else most recent.
const featured = featuredArticles[0];
const hero = featured ?? articles[0];

// Grid = everything else (excludes whatever became the hero), capped at 4.
const grid = articles.filter((a) => a.id !== hero?.id).slice(0, 4);

// Cheap hero excerpt: first non-empty paragraph of the raw markdown body,
// stripped of inline markdown. Good enough for a teaser; nothing rendered.
function excerptOf(raw: string): string {
  const firstPara = raw
    .split(/\n{2,}/)
    .map((p) => p.trim())
    .find((p) => p.length > 0 && !p.startsWith("#"));
  if (!firstPara) return "";
  return firstPara
    .replace(/!\[[^\]]*\]\([^)]*\)/g, "")          // images
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")        // links
    .replace(/[*_`]/g, "")                          // emphasis/code marks
    .replace(/\s+/g, " ")
    .trim();
}

const heroExcerpt = hero ? excerptOf(hero.body ?? "") : "";
---

<BaseLayout
  title="The Corn — Port Perry's most vigilant satirical newspaper"
  description="Satirical small-town news from Port Perry, Uxbridge, and Beaverton. Fictional, affectionate, occasionally accurate."
>
  <Masthead />

  <main class="front-page">
    {hero ? (
      <ArticleCard article={hero} variant="hero" excerpt={heroExcerpt} />
    ) : (
      <p class="empty">No articles published yet. Check back soon.</p>
    )}

    {grid.length > 0 && (
      <section class="grid" aria-label="More from this edition">
        {grid.map((article) => (
          <ArticleCard article={article} variant="grid" />
        ))}
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .front-page {
    padding: 1em 0 0;
  }

  .empty {
    text-align: center;
    font-style: italic;
    color: var(--color-muted);
    padding: 2em 0;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.8em;
    padding: 0 0 1em;
  }

  /* Two columns at tablet+ widths. */
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 2em;
      row-gap: 2em;
    }
  }
</style>
